# App
APP_ENV=development
APP_NAME=AlgoMentor AI
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=algomentor
POSTGRES_USER=algomentor
POSTGRES_PASSWORD=algomentor_password
DATABASE_URL=postgresql+psycopg://algomentor:algomentor_password@postgres:5432/algomentor?connect_timeout=5

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# MVP Flags
ENABLE_DEV_USER=true
DEV_USER_ID=00000000-0000-0000-0000-000000000001
ENABLE_CODE_EXECUTION=false
ENABLE_RUNTIME_AI_SETTINGS=false
ENABLE_PERSISTENT_AI_SETTINGS=false
PERSISTENT_AI_SETTINGS_PATH=.runtime-ai-settings.json

# Isolated Judge (Post-MVP Phase 10)
# Keep code execution disabled until the Judge service and a strong random token are configured.
JUDGE_BASE_URL=http://localhost:9000
JUDGE_INTERNAL_TOKEN=
JUDGE_REQUEST_TIMEOUT_SECONDS=60
JUDGE_REQUEST_HARD_TIMEOUT_SECONDS=50
JUDGE_STALE_CONTAINER_SECONDS=300
SUBMISSION_MAX_IN_FLIGHT=2
JUDGE_MAX_CONCURRENT=2
JUDGE_COMPILE_TIMEOUT_SECONDS=10
JUDGE_CASE_TIMEOUT_SECONDS=2
JUDGE_TOTAL_TIMEOUT_SECONDS=30
JUDGE_MEMORY_LIMIT_MB=512
JUDGE_CPU_LIMIT=1
JUDGE_CONTAINER_PIDS_LIMIT=128
JUDGE_RUNTIME_PROCESS_LIMIT=64
JUDGE_WORKSPACE_LIMIT_MB=64
JUDGE_OUTPUT_LIMIT_BYTES=65536
JUDGE_RUNNER_IMAGE=algomentor-judge-runner:phase10

# AI
# Leave provider values empty in local development to return AI_CONFIG_MISSING safely.
AI_PROVIDER=openai_compatible
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_SECONDS=60
AI_MAX_RETRIES=1

# Security
SECRET_KEY=change-me-in-production-32-bytes-long!!
ACCESS_TOKEN_EXPIRE_MINUTES=1440
